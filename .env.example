# Supabase（https://supabase.com/dashboard のプロジェクト設定から取得）
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Clerk（https://dashboard.clerk.com → API Keys から取得）
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# PostHog（Phase A テレメトリ — https://app.posthog.com のプロジェクト設定から取得）
# 未設定のままでも起動・動作する。設定するとイベントが PostHog に送信される。
POSTHOG_API_KEY=phc_...
POSTHOG_HOST=https://app.posthog.com

# Supabase MCP（.mcp.json で使用 — https://supabase.com/dashboard/account/tokens から取得）
# シェルの ~/.zshrc または ~/.zshenv に追記: export SUPABASE_ACCESS_TOKEN=sbp_...
SUPABASE_ACCESS_TOKEN=sbp_...
