# =============================================================================
# 環境別セットアップガイド
#
# ローカル開発:
#   1. `pnpm supabase start` でローカルSupabaseを起動
#   2. `pnpm supabase status` で表示されるURLとanon keyを下記に設定
#   3. 型生成: `pnpm db:types:local`
#
# 本番（Vercel等）:
#   1. Supabase Dashboardのプロジェクト設定からURLとanon keyを取得
#   2. 型生成: `pnpm db:types`
# =============================================================================

# --- ローカル開発用（supabase start 後に確認: pnpm supabase status） ---
# NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# NEXT_PUBLIC_SUPABASE_ANON_KEY=<supabase status の anon key>

# --- 本番用（https://supabase.com/dashboard のプロジェクト設定から取得） ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Clerk（https://dashboard.clerk.com → API Keys から取得）
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# PostHog（Phase A テレメトリ — https://app.posthog.com のプロジェクト設定から取得）
# 未設定のままでも起動・動作する。設定するとイベントが PostHog に送信される。
# NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN = クライアントサイド（posthog-js）用
# POSTHOG_API_KEY = サーバーサイド（posthog-node）用（通常は同じキー値を設定）
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=phc_...
POSTHOG_API_KEY=phc_...
POSTHOG_HOST=https://us.i.posthog.com

# Supabase MCP（.mcp.json で使用 — https://supabase.com/dashboard/account/tokens から取得）
# シェルの ~/.zshrc または ~/.zshenv に追記: export SUPABASE_ACCESS_TOKEN=sbp_...
SUPABASE_ACCESS_TOKEN=sbp_...
