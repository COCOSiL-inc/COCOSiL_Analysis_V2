# =============================================================================
# データベース設定
#
# ローカル開発:
#   NEXT_PUBLIC_SUPABASE_URL / ANON_KEY を設定しない → SQLite (dev.db) を自動使用
#
# 本番 (Vercel / Supabase):
#   以下の2変数を設定 → Supabase を使用
# =============================================================================

# Supabase（本番のみ — https://supabase.com/dashboard のプロジェクト設定から取得）
# ローカルでは設定不要（SQLite が使われる）
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Clerk（https://dashboard.clerk.com → API Keys から取得）
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# PostHog（Phase A テレメトリ — 未設定でも起動・動作する）
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=phc_...
POSTHOG_API_KEY=phc_...
POSTHOG_HOST=https://us.i.posthog.com

# Supabase MCP（.mcp.json で使用 — https://supabase.com/dashboard/account/tokens から取得）
# シェルの ~/.zshrc に追記: export SUPABASE_ACCESS_TOKEN=sbp_...
SUPABASE_ACCESS_TOKEN=sbp_...
