# manifest.yaml template for skill publishing
# Copy this to .claude/skills/<skill-name>/manifest.yaml and fill in.
# See references/manifest-spec.md for full schema.

name: <skill-name>                    # Must match SKILL.md frontmatter name
version: 0.1.0                         # SemVer (initial: 0.1.0)
description: |
  <1-3 line description, extracted from SKILL.md description>

authors:
  - <your name or git config user.name>

license: MIT                           # SPDX license id

compatibility:
  claude_code: ">=1.0"
  claude_models:
    - opus-4.7
    - sonnet-4.6
    - haiku-4.5

dependencies:
  skills: []                           # Other skills this depends on
                                       # e.g., ["skill-shipper@>=0.1.0"]
  external: []                         # External CLIs / runtimes
                                       # e.g., ["gh: '>=2.0'", "uv: '>=0.4'"]

config_required: []                    # Placeholders that user must fill on install
                                       # e.g.:
                                       # - product:
                                       #     description: "Target product name"
                                       #     type: string

config_optional: []                    # Optional tunable parameters

files:
  required:
    - SKILL.md
    - manifest.yaml
  optional:
    - SESSION_TEMPLATE.md
    - references/
    - templates/
    - evals/evals.json
    - LICENSE

test_eval:
  pass_rate_min: 0.7
  benchmark_command: /benchmark-skill <skill-name>

tags: []                               # Search tags

repository:
  url: <publish 元 git URL>
  path: .claude/skills/<skill-name>/
  commit: <publish 時の HEAD SHA、自動入力>

published_at: <ISO 8601、自動入力>
last_updated: <ISO 8601、自動入力>

abstraction:
  fully_abstracted: true               # Set false if there are warnings below
  warnings: []
  redacted_count: 0

deprecation:
  status: active                       # active | deprecated | archived
